{
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "installCommand": "npm install",
    "framework": "nextjs",
    "regions": [
        "cdg1"
    ],
    "crons": [
        { "path": "/api/cron/refresh",      "schedule": "0 0 * * *" },
        { "path": "/api/cron/eth-refresh",  "schedule": "0 1 * * *" }
    ],
    "functions": {
        "src/app/api/cron/**/*.ts": {
            "maxDuration": 60
        },
        "src/app/api/**/*.ts": {
            "maxDuration": 30
        }
    },
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "s-maxage=300, stale-while-revalidate=600"
                }
            ]
        }
    ]
}